# .env  – файл, который читается в docker‑compose
APP_PORT=8080

# JWT
JWT_SECRET=very-secret-key
JWT_TTL_MINUTES=60

# ==== Важно! ==== #
# Для работы внутри Docker‑Compose указываем имя контейнера db,
# а не localhost.
POSTGRES_DSN=postgres://vk:vk@db:5432/vk?sslmode=disable

# Redis тоже должен указывать на контейнер cache
REDIS_ADDR=cache:6379

# RabbitMQ (если используете)
AMQP_URL=amqp://guest:guest@rabbit:5672/
